<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Camera: reads YOUR OWN hand only (see HandRecognizer / README ethics). -->
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Microphone: transcribes friends' spoken calls to rebuild the PUBLIC board. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Network: required for the LLM assistant (Claude / OpenAI-compatible endpoints). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="Mahjong Coach"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!--
          Orientation is driven per-screen from Compose (see coach/LockOrientation.kt):
          Coach pins landscape, every other tab pins portrait. Declaring the activity
          as `unspecified` lets those calls win.
        -->
        <!--
          FileProvider for handing camera capture Uris to the system camera
          app (see score/PhotoCapture). Authority must match the BuildConfig
          applicationId so debug + release builds both work.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
