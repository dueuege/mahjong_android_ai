<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-build only. Allows plaintext HTTP to specific hosts used during
  development (some self-hosted LLM gateways only speak HTTP on non-443 ports).
  Release builds use Android's default policy: HTTPS only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">c2846.top</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
