<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-build manifest overlay: points the app at a network-security config
  that whitelists a few cleartext-HTTP hosts (self-hosted LLM gateways used
  during development). Release builds inherit Android's default HTTPS-only
  policy from the main manifest.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
